---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import ClientsSection from '@components/sections/landing/ClientsSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import PricingSection from '@components/sections/pricing/PricingSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import AnnouncementBanner from '@components/ui/banners/AnnouncementBanner.astro';
import heroImage from '@images/hero-image66.avif';
import heroDarkImage from '@images/hero-image66.avif';
import faqs from '@data/faqs.json';
import features from '@data/features.json';
import pricing from '@data/pricing.json';
import construction from '@images/construction-image.avif';
import tools from '@images/automated-tools.avif';
import dashboard from '@images/dashboard-image.avif';
import testimonialAvatar from '@images/testis.webp';
import { partnersData } from '@/data_files/constants';

const avatarSrcs: Array<string> = [
  'https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
];
---

<MainLayout>
  <!-- <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle="Explore ScrewFast on GitHub"
    url="https://github.com/mearashadowfax/ScrewFast"
  /> -->

  <HeroSection
    title=`Power Your AI with <span
        class="text-blue-500 dark:text-blue-400" style="color:#3b82f6;">PAVIi.AI</span>`
    subTitle="A one-stop platform for AI infrastructure that provids technology needed to build, run, and scale AI solutions with confidence."
    primaryBtn="Start Exploring"
    primaryBtnURL="/products"
    secondaryBtn="Contact Us"
    secondaryBtnURL="https://cal.com/buckleson-group/30min"
    withReview={true}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">4.8</span> / 5`
    starCount={4}
    reviews=`From Over <span class="font-bold">12.8k</span> Reviews`
    src={heroImage}
    darkSrc={heroDarkImage}
    alt="Stack of PAVIi.AI product boxes containing assorted A.I tools"
  />

  <!-- <ClientsSection
    title="Trusted by "
    subTitle="Experience the partnership chosen by best organizations."
    partners={partnersData}
  /> -->

  <FeaturesGeneral
    title="Meeting Industry Demands"
    subTitle="At PAVIi.AI, we tackle the unique challenges encountered in the AI infrastructure sector. From cutting-edge tools to expert services, we're dedicated to helping you overcome obstacles and achieve your goals."
    features={features}
  />

  <FeaturesNavs
    title=`Customize <span class="text-blue-500 dark:text-blue-400" style="color: #3b82f6;">PAVIi.AI</span>'s offerings to perfectly suit your hardware and construction needs.`
    tabs={[
      {
        heading: 'Specialized AI Solutions',
        content:
          "Different tools and services tailored for different AI requirements, helping businesses build, deploy, and scale intelligent solutions with better performance and outcomes.",
        svg: 'tools',
        src: tools,
        alt: 'Illustration of AI infrastructure tools and systems in a modern technology setting',
        first: true,
      },
      {
        heading: 'Seamless Integration',
        content:
          "Integrate AI capabilities into your existing systems without disrupting current workflows. Our flexible infrastructure works seamlessly with your technology stack, reducing complexity and deployment time.",
        svg: 'dashboard',
        src: dashboard,
        alt: 'A screenshot or graphic representation of the intuitive dashboard',
        second: true,
      },
      {
        heading: 'Secure & Sovereign Infrastructure',
        content:
          "Protect your data with blockchain-backed security and self-hosted deployment options, ensuring privacy, ownership, and full control over your AI operations.",
        svg: 'house',
        src: construction,
        alt: 'Gray metal building frame near tower crane during daytime',
      },
    ]}
  />

 <TestimonialsSection
title="Trusted by Businesses Building with AI"
subTitle="From healthcare platforms to enterprise applications, organizations rely on PAVII.AI to simplify AI infrastructure, accelerate deployment, and scale securely."

testimonials={[
{
content:
'PAVII.AI helped us streamline our AI infrastructure without disrupting our existing systems. The deployment process was smooth, the platform was easy to integrate, and the security-first approach gave us confidence in scaling our operations.',
author: 'DEVARAAYA ATLURI',
role: 'CEO | CaterHealth',
avatarSrc: testimonialAvatar,
},
]}


   statistics={[
  {
    count: '10+',
    description:
      'AI infrastructure services covering compute, agents, data, security, and deployment',
  },
  {
    count: '100%',
    description:
      'self-hostable solutions for organizations requiring complete data ownership and control',
  },
  {
    count: '24/7',
    description:
      'automated infrastructure monitoring and orchestration for uninterrupted operations',
  },
  {
    count: '1',
    description:
      'unified platform to build, deploy, manage, and scale AI applications',
  },
]}

  <!-- <PricingSection pricing={pricing} /> -->

  <FAQ title="Frequently<br />asked questions" faqs={faqs} />

<HeroSectionAlt
  title="Build, Deploy, and Scale AI with Confidence"
  subTitle="A complete AI infrastructure platform designed to help businesses launch AI solutions faster, integrate seamlessly, and maintain full control over their data."
  url="https://cal.com/buckleson-group/30min"
/>
</MainLayout>
